---
import type { ResumeData } from "../data/resume";
interface Download {
  label: string;
  href: string;
}
interface Props {
  data: ResumeData;
  downloads: Download[];
}
const { data, downloads } = Astro.props;
---

<div class="screen">
  <nav class="toolbar">
    <a href="/" class="tb-link">← Back to site</a>
    <span class="tb-actions">
      {downloads.map((d) => (
        <a href={d.href} class="tb-btn" download>{d.label}</a>
      ))}
    </span>
  </nav>

  <article class="paper">
    <header class="r-head">
      <h1>{data.name}</h1>
      <p class="r-headline">{data.headline}</p>
      <p class="r-contact">{data.contact.join("  |  ")}</p>
    </header>

    <section>
      <h2>Summary</h2>
      <p class="r-summary">{data.summary}</p>
    </section>

    <section>
      <h2>Professional Experience</h2>
      {data.experience.map((role) => (
        <div class="role">
          <div class="role-top">
            <span class="role-title">{role.title}</span>
            <span class="role-dates">{role.dates}</span>
          </div>
          <div class="role-sub">{role.org} | {role.location}</div>
          <ul>
            {role.bullets.map((b) => <li>{b}</li>)}
          </ul>
        </div>
      ))}
    </section>

    {data.projects && (
      <section>
        <h2>Selected Projects — AI &amp; Automation</h2>
        {data.projects.map((p) => (
          <p class="proj">
            <span class="proj-name">{p.name}.</span> {p.line}
          </p>
        ))}
      </section>
    )}

    <section>
      <h2>Education</h2>
      {data.education.map((e) => <p class="r-line">{e}</p>)}
      <p class="r-line"><strong>Certifications:</strong> {data.certifications}</p>
    </section>

    <section>
      <h2>Skills</h2>
      {data.skills.map((s) => (
        <p class="r-line"><strong>{s.label}:</strong> {s.value}</p>
      ))}
    </section>
  </article>
</div>

<style>
  .screen {
    min-height: 100vh;
    background: #0c0a08;
    padding: 1.5rem 1rem 4rem;
  }
  .toolbar {
    max-width: 8.5in;
    margin: 0 auto 1.25rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
    justify-content: space-between;
  }
  .tb-link {
    color: #cbbfae;
    font-family: ui-sans-serif, system-ui, sans-serif;
    font-size: 0.85rem;
    text-decoration: none;
  }
  .tb-link:hover { color: #f59e0b; }
  .tb-actions { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .tb-btn {
    background: #f59e0b;
    color: #0c0a08;
    font-family: ui-sans-serif, system-ui, sans-serif;
    font-size: 0.8rem;
    font-weight: 700;
    text-decoration: none;
    padding: 0.5rem 0.9rem;
    border-radius: 6px;
  }
  .tb-btn:hover { background: #fbbf24; }

  .paper {
    max-width: 8.5in;
    margin: 0 auto;
    background: #fff;
    color: #1a1a1a;
    padding: 0.55in 0.6in;
    border-radius: 4px;
    font-family: Arial, Helvetica, sans-serif;
    font-size: 10.5pt;
    line-height: 1.4;
  }
  .r-head { text-align: center; margin-bottom: 0.5rem; }
  .r-head h1 { font-size: 20pt; margin: 0; letter-spacing: 0.5px; }
  .r-headline { font-size: 11pt; font-weight: 700; margin: 2px 0; color: #333; }
  .r-contact { font-size: 9.5pt; color: #444; margin: 2px 0; }

  h2 {
    font-size: 11pt;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    border-bottom: 1.5px solid #333;
    padding-bottom: 2px;
    margin: 14px 0 7px;
  }
  .r-summary { margin: 0; }

  .role { margin-bottom: 9px; }
  .role-top { display: flex; justify-content: space-between; gap: 1rem; }
  .role-title { font-weight: 700; }
  .role-dates { font-weight: 700; white-space: nowrap; }
  .role-sub { font-style: italic; color: #444; margin-bottom: 2px; }
  ul { margin: 3px 0 0; padding-left: 18px; }
  li { margin-bottom: 2px; }

  .proj { margin: 0 0 5px; }
  .proj-name { font-weight: 700; }
  .r-line { margin: 0 0 3px; }

  @media print {
    @page { size: Letter; margin: 0.5in; }
    .screen { background: #fff; padding: 0; min-height: 0; }
    .toolbar { display: none; }
    .paper {
      max-width: none;
      margin: 0;
      padding: 0;
      border-radius: 0;
      font-size: 10pt;
    }
  }
</style>
