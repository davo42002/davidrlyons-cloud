---
import { site } from "../data/site";
const initials = site.name
  .split(" ")
  .map((w) => w[0])
  .join("");
---

<section class="hero" id="top">
  <div class="container hero-inner">
    <div class="hero-text">
      <p class="label hero-eyebrow">{site.role}</p>
      <h1 class="hero-name">{site.name}</h1>
      <p class="hero-tagline">
        {site.taglineLead} <span class="accent">{site.taglineAccent}</span>
      </p>
      <p class="hero-intro">{site.intro}</p>
      <div class="hero-cta">
        <a href="#work" class="btn btn-primary">View my work</a>
        <a href={site.resume} class="btn btn-ghost">Resume</a>
        <a href={site.github} class="btn btn-ghost" rel="noopener">GitHub</a>
      </div>
    </div>

    <figure class="hero-photo">
      <span class="photo-fallback" aria-hidden="true">{initials}</span>
      <img
        src={site.photo}
        alt={site.photoAlt}
        width="440"
        height="520"
        loading="eager"
        fetchpriority="high"
        onerror="this.style.display='none'"
      />
    </figure>
  </div>
</section>

<style>
  .hero {
    padding-block: clamp(4rem, 3rem + 7vw, 8rem) var(--space-section);
  }
  .hero-inner {
    display: grid;
    grid-template-columns: 1.25fr 0.9fr;
    gap: clamp(2rem, 1rem + 5vw, 5rem);
    align-items: center;
  }
  .hero-eyebrow {
    margin-bottom: var(--space-4);
  }
  .hero-name {
    font-size: clamp(2.8rem, 1.6rem + 5vw, 5rem);
    line-height: 1;
  }
  .hero-tagline {
    margin-top: var(--space-4);
    font-size: var(--fs-h3);
    font-weight: 600;
    color: var(--text);
  }
  .hero-tagline .accent {
    color: var(--accent);
  }
  .hero-intro {
    margin-top: var(--space-6);
    max-width: 38rem;
    font-size: var(--fs-lead);
    color: var(--text-muted);
  }
  .hero-cta {
    margin-top: var(--space-8);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }
  .btn {
    display: inline-flex;
    align-items: center;
    border-radius: var(--radius-sm);
    padding: 0.7rem 1.2rem;
    font-size: var(--fs-sm);
    font-weight: 600;
    transition: transform var(--dur-fast) var(--ease-out-expo),
      background var(--dur-fast), border-color var(--dur-fast), color
      var(--dur-fast);
  }
  .btn:hover {
    transform: translateY(-2px);
  }
  .btn-primary {
    background: var(--accent);
    color: var(--accent-contrast) !important;
    box-shadow: 0 8px 30px var(--accent-glow);
  }
  .btn-primary:hover {
    background: var(--accent-hover);
  }
  .btn-ghost {
    border: 1px solid var(--border-strong);
    color: var(--text);
  }
  .btn-ghost:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  /* photo */
  .hero-photo {
    position: relative;
    justify-self: center;
    width: min(100%, 24rem);
    aspect-ratio: 11 / 13;
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--border-strong);
    background: radial-gradient(
      120% 120% at 70% 0%,
      color-mix(in srgb, var(--accent) 22%, var(--bg-card)) 0%,
      var(--bg-card) 60%
    );
    box-shadow: 0 30px 80px -30px var(--accent-glow);
  }
  .hero-photo img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .photo-fallback {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: clamp(2.5rem, 1rem + 6vw, 4rem);
    letter-spacing: 0.05em;
    color: var(--accent);
    opacity: 0.55;
  }

  @media (max-width: 820px) {
    .hero-inner {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
    .hero-photo {
      grid-row: 1;
      width: min(100%, 16rem);
      aspect-ratio: 1 / 1;
      border-radius: 50%;
    }
    .hero-intro {
      max-width: none;
    }
  }
</style>
