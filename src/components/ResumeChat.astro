---
const suggestions = [
  "What's David's leadership & management experience?",
  "Has he managed P&L or budgets?",
  "What has he built with AI?",
];
---

<div class="chat" data-chat>
  <button class="launch" data-open aria-label="Ask my résumé">
    <span class="dot"></span> Ask my résumé
  </button>

  <section class="panel" data-panel hidden aria-label="Résumé assistant">
    <header class="p-head">
      <div>
        <strong>Ask my résumé</strong>
        <span class="p-sub">AI trained on David's background</span>
      </div>
      <button class="close" data-close aria-label="Close">×</button>
    </header>

    <div class="log" data-log>
      <div class="msg bot">
        Hi — I'm an AI assistant trained on David's experience. Ask me anything
        about his leadership, management, or what he's built.
      </div>
      <div class="chips">
        {suggestions.map((s) => <button class="chip" data-chip>{s}</button>)}
      </div>
    </div>

    <form class="input" data-form>
      <input
        type="text"
        name="q"
        placeholder="Type a question…"
        autocomplete="off"
        maxlength="600"
        data-input
      />
      <button type="submit" data-send aria-label="Send">→</button>
    </form>
  </section>
</div>

<style>
  .chat { position: fixed; right: 1.25rem; bottom: 1.25rem; z-index: 80; }
  .launch {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--accent);
    color: var(--accent-contrast);
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: var(--fs-sm);
    border: 0;
    border-radius: 100px;
    padding: 0.7rem 1.1rem;
    cursor: pointer;
    box-shadow: 0 10px 30px var(--accent-glow);
    transition: transform var(--dur-fast) var(--ease-out-expo);
  }
  .launch:hover { transform: translateY(-2px); }
  .launch .dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--accent-contrast); opacity: 0.8;
  }
  .panel {
    position: absolute;
    right: 0; bottom: 0;
    width: min(92vw, 380px);
    height: min(70vh, 540px);
    display: flex;
    flex-direction: column;
    background: var(--bg-raised);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: 0 30px 80px -20px rgba(0,0,0,0.7);
  }
  .panel[hidden] { display: none; }
  .p-head {
    display: flex; align-items: center; justify-content: space-between;
    padding: 0.9rem 1rem;
    border-bottom: 1px solid var(--border);
  }
  .p-head strong { display: block; font-size: var(--fs-sm); }
  .p-sub {
    font-family: var(--font-mono);
    font-size: 0.66rem; letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--text-dim);
  }
  .close { background: none; border: 0; color: var(--text-muted); font-size: 1.4rem; cursor: pointer; line-height: 1; }
  .close:hover { color: var(--accent); }
  .log { flex: 1; overflow-y: auto; padding: 1rem; display: flex; flex-direction: column; gap: 0.7rem; }
  .msg {
    max-width: 85%;
    font-size: var(--fs-sm);
    line-height: 1.5;
    padding: 0.6rem 0.8rem;
    border-radius: 12px;
  }
  .msg.bot { background: var(--bg-card); border: 1px solid var(--border); color: var(--text-muted); align-self: flex-start; border-bottom-left-radius: 3px; }
  .msg.user { background: var(--accent); color: var(--accent-contrast); align-self: flex-end; border-bottom-right-radius: 3px; }
  .msg.typing { color: var(--text-dim); font-style: italic; }
  .chips { display: flex; flex-direction: column; gap: 0.4rem; margin-top: 0.2rem; }
  .chip {
    text-align: left;
    background: none;
    border: 1px solid var(--border);
    color: var(--text-muted);
    font-family: var(--font-sans);
    font-size: 0.8rem;
    border-radius: 100px;
    padding: 0.45rem 0.8rem;
    cursor: pointer;
  }
  .chip:hover { border-color: var(--accent); color: var(--accent); }
  .input { display: flex; gap: 0.5rem; padding: 0.8rem; border-top: 1px solid var(--border); }
  .input input {
    flex: 1;
    background: var(--bg);
    border: 1px solid var(--border-strong);
    border-radius: 100px;
    color: var(--text);
    font-family: var(--font-sans);
    font-size: var(--fs-sm);
    padding: 0.55rem 0.9rem;
  }
  .input input:focus { outline: none; border-color: var(--accent); }
  .input button {
    flex: none;
    width: 2.4rem;
    background: var(--accent);
    color: var(--accent-contrast);
    border: 0; border-radius: 50%;
    font-size: 1rem; cursor: pointer;
  }
  .input button:disabled { opacity: 0.5; cursor: default; }
  @media (prefers-reduced-motion: reduce) {
    .launch { transition: none; }
  }
</style>

<script>
  const root = document.querySelector("[data-chat]");
  if (root) {
    const panel = root.querySelector("[data-panel]") as HTMLElement;
    const openBtn = root.querySelector("[data-open]") as HTMLButtonElement;
    const closeBtn = root.querySelector("[data-close]") as HTMLButtonElement;
    const form = root.querySelector("[data-form]") as HTMLFormElement;
    const input = root.querySelector("[data-input]") as HTMLInputElement;
    const sendBtn = root.querySelector("[data-send]") as HTMLButtonElement;
    const log = root.querySelector("[data-log]") as HTMLElement;

    const setOpen = (open: boolean) => {
      panel.hidden = !open;
      openBtn.style.display = open ? "none" : "";
      if (open) input.focus();
    };
    openBtn.addEventListener("click", () => setOpen(true));
    closeBtn.addEventListener("click", () => setOpen(false));

    const add = (text: string, who: string) => {
      const el = document.createElement("div");
      el.className = "msg " + who;
      el.textContent = text;
      log.appendChild(el);
      log.scrollTop = log.scrollHeight;
      return el;
    };

    let busy = false;
    const ask = async (q: string) => {
      if (busy || !q.trim()) return;
      busy = true;
      sendBtn.disabled = true;
      root.querySelector(".chips")?.remove();
      add(q, "user");
      input.value = "";
      const typing = add("Thinking…", "bot typing");
      try {
        const res = await fetch("/api/chat", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ message: q }),
        });
        const data = await res.json();
        typing.remove();
        add(data.reply || data.error || "Something went wrong.", "bot");
      } catch {
        typing.remove();
        add("Network error — please try again.", "bot");
      } finally {
        busy = false;
        sendBtn.disabled = false;
        input.focus();
      }
    };

    form.addEventListener("submit", (e) => {
      e.preventDefault();
      ask(input.value);
    });
    root.querySelectorAll("[data-chip]").forEach((c) =>
      c.addEventListener("click", () => ask((c as HTMLElement).textContent || ""))
    );
  }
</script>
