---
import "../styles/global.css";
import { site } from "../data/site";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import MetricsBand from "../components/MetricsBand.astro";
import Experience from "../components/Experience.astro";
import SelectedWork from "../components/SelectedWork.astro";
import Capabilities from "../components/Capabilities.astro";
import Recommendations from "../components/Recommendations.astro";
import About from "../components/About.astro";
import Footer from "../components/Footer.astro";

const ogImage = new URL("/og.png", site.url).href;

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: site.name,
  jobTitle: "Operations Leader & AI / Automation Builder",
  url: site.url,
  email: `mailto:${site.email}`,
  image: new URL("/portrait.jpg", site.url).href,
  address: {
    "@type": "PostalAddress",
    addressLocality: "Forney",
    addressRegion: "TX",
    addressCountry: "US",
  },
  alumniOf: {
    "@type": "CollegeOrUniversity",
    name: "Texas A&M University",
  },
  worksFor: { "@type": "Organization", name: "American Tire Distributors" },
  sameAs: [site.github, site.linkedin],
  knowsAbout: [
    "Operations Management",
    "Supply Chain & Logistics",
    "Team Leadership",
    "Power BI",
    "Data Analysis",
    "AI Agents",
    "Automation",
    "Python",
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="theme-color" content="#0c0a08" />
    <meta name="generator" content={Astro.generator} />

    <title>{site.name} — {site.role}</title>
    <meta name="description" content={site.description} />
    <link rel="canonical" href={site.url} />
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(personSchema)}
    />


    <meta property="og:type" content="website" />
    <meta property="og:url" content={site.url} />
    <meta property="og:title" content={`${site.name} — ${site.role}`} />
    <meta property="og:description" content={site.description} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${site.name} — ${site.role}`} />
    <meta name="twitter:description" content={site.description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
    />
  </head>

  <body>
    <a class="skip-link" href="#work">Skip to content</a>
    <Nav />
    <main>
      <Hero />
      <MetricsBand />
      <Experience />
      <SelectedWork />
      <Capabilities />
      <Recommendations />
      <About />
    </main>
    <Footer />

    <style>
      .skip-link {
        position: absolute;
        left: -9999px;
        top: 0;
        background: var(--accent);
        color: var(--accent-contrast);
        padding: 0.6rem 1rem;
        border-radius: 0 0 var(--radius-sm) 0;
        z-index: 100;
      }
      .skip-link:focus {
        left: 0;
        color: var(--accent-contrast);
      }
    </style>

    <script>
      // Mark JS available (CSS hides .reveal only when .js is present),
      // then reveal on scroll. No-JS and reduced-motion users see content
      // immediately because .reveal defaults to visible.
      const root = document.documentElement;
      const reduce = window.matchMedia(
        "(prefers-reduced-motion: reduce)"
      ).matches;

      if (!reduce) {
        root.classList.add("js");
        const els = document.querySelectorAll(".reveal");
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add("is-visible");
                io.unobserve(e.target);
              }
            }
          },
          { rootMargin: "0px 0px -10% 0px", threshold: 0.1 }
        );
        els.forEach((el) => io.observe(el));
      }
    </script>
  </body>
</html>
